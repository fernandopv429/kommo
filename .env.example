# OPENAI_API_KEY: Required for OpenAI API calls.
# Inject this via environment variables or secrets manager.
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Configure this with your actual production URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Kommo Integrations Secrets
KOMMO_CLIENT_ID=""
KOMMO_CLIENT_SECRET=""
KOMMO_REDIRECT_URI="http://localhost:3000/auth/kommo/callback"

# Database connection
DATABASE_URL="postgresql://user:password@localhost:5432/kommo_hub?schema=public"

# Evolution API
EVOLUTION_API_KEY=""
EVOLUTION_URL=""

# Redis
REDIS_URL="redis://:sua_senha_aqui@host:porta/0"