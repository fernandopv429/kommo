generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model KommoConnection {
  id              String   @id @default(uuid())
  tenantId        String   // ID do usuário/empresa no meu sistema
  accountName     String?  // Nome da Empresa retornado pela Kommo
  kommoAccountId  String   @unique // ID interno da conta na Kommo
  kommoSubdomain  String
  accessToken     String
  refreshToken    String
  expiresAt       DateTime
  isActive        Boolean  @default(true) // Controle de Ativo/Inativo
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

model InteractionLog {
  id              String   @id @default(uuid())
  tenantId        String   // ID do cliente/empresa dono do fluxo
  leadId          String?  // ID do lead na Kommo
  whatsappNumber  String   // Telefone do cliente
  incomingMessage String   // O que o cliente digitou no WhatsApp
  aiResponse      String?  // O que a IA respondeu (se houver)
  actionTaken     String?  // Ex: "Moveu para etapa X", "Apenas respondeu"
  status          String   // "SUCCESS" ou "ERROR"
  errorMessage    String?  // Detalhes técnico caso falhe
  createdAt       DateTime @default(now())
}

model KommoLeadCache {
  id              String   @id @default(uuid())
  tenantId        String   
  phoneNumber     String   
  leadId          Int
  name            String?
  price           Int?
  statusId        Int?
  pipelineId      Int?
  tags            String[] // Arrays of strings are supported in PostgreSQL
  customFields    Json?    // Use Json for dynamic mapping
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([tenantId, phoneNumber])
}

model SystemSetting {
  key   String @id // e.g., "N8N_WEBHOOK_URL"
  value String
}
