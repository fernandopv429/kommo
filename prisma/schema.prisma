generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model KommoConnection {
  id              String   @id @default(uuid())
  tenantId        String   // ID do usuário/empresa no meu sistema
  accountName     String?  // Nome da Empresa retornado pela Kommo
  kommoAccountId  String   @unique // ID interno da conta na Kommo
  kommoSubdomain  String
  accessToken     String
  refreshToken    String
  expiresAt       DateTime
  isActive        Boolean  @default(true) // Controle de Ativo/Inativo
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}
